{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability for the main CrossHook window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "https://www.protondb.com/**" }]
    }
  ]
}
