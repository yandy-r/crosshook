{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrossHook",
  "identifier": "io.github.yandy-r.crosshook",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CrossHook",
        "width": 1280,
        "height": 800,
        "theme": "Dark",
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; img-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$LOCALDATA/crosshook/cache/images/**", "$LOCALDATA/crosshook/media/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "resources": ["../runtime-helpers/*.sh"],
    "icon": ["icons/icon.png"]
  }
}
