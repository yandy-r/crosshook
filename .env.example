# ==================================================
# choochoo-loader - Environment Variables
# ==================================================
# Copy this file to .env and fill in the values
# .env is gitignored and should never be committed

# Application settings
# APP_ENV=development
# APP_DEBUG=true
# LOG_LEVEL=info

# Database configuration
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=choochoo-loader_dev
# DB_USER=postgres
# DB_PASSWORD=

# API Keys and Secrets (use 1Password or similar)
# API_KEY=
# SECRET_KEY=
# JWT_SECRET=

# External services
# REDIS_URL=redis://localhost:6379
# RABBITMQ_URL=amqp://localhost:5672

# Feature flags
# ENABLE_FEATURE_X=false
# ENABLE_METRICS=true
